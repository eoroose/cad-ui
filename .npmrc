# Hoist @types/* and prisma-related packages to root node_modules.
# Without this pnpm keeps them in the virtual store only, causing:
#   - TS2742 "inferred type cannot be named" errors (for @types)
#   - Prisma generate "Could not resolve @prisma/client" errors (for prisma)
public-hoist-pattern[]=@types/*
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*
